# Convex deployment URL (set by init_app_project tool or npx convex dev)
VITE_CONVEX_URL=

# For local development with npx convex dev
# CONVEX_DEPLOY_KEY=

# Auth private key (RSA 2048, generated automatically)
# AUTH_PRIVATE_KEY=

# ─── LLM Provider — Anthropic ─────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ─── LLM Provider — OpenAI ────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Set at least one provider's API key to enable AI features.
# Override MODEL and BASE_URL to use custom endpoints
# (Azure OpenAI, vLLM, Ollama, LiteLLM proxy, etc.)
